{
	"name": "@absolutejs/pwa",
	"version": "0.4.0",
	"description": "Framework-agnostic PWA + Web Push primitives — web app manifest, push service worker, VAPID sender, and browser subscription glue",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/absolutejs/pwa.git"
	},
	"homepage": "https://github.com/absolutejs/pwa",
	"bugs": {
		"url": "https://github.com/absolutejs/pwa/issues"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"license": "MIT",
	"author": "Alex Kahn",
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"absolutejs",
		"pwa",
		"web-push",
		"push-notifications",
		"service-worker",
		"manifest",
		"vapid"
	],
	"scripts": {
		"build": "rm -rf dist && bun build src/index.ts src/client.ts --outdir dist --sourcemap --target=bun --external web-push && tsc --project tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"format": "prettier --write \"./**/*.{ts,json,md}\"",
		"release": "bun run format && bun run typecheck && bun run build && bun publish"
	},
	"dependencies": {
		"web-push": "^3.6.7"
	},
	"devDependencies": {
		"@types/bun": "1.3.14",
		"@types/web-push": "^3.6.4",
		"prettier": "3.5.3",
		"typescript": "5.8.3"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.js",
			"default": "./dist/client.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	]
}
